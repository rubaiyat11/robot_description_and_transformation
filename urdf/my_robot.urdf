<?xml version ="1.0"?>
<robot name="my_first_robot">

<link name ="chassis">
    <visual>
        <geometry>
            <box size="1 1 1"/>
        </geometry>
        <material name="red">
            <color rgba="1 0 0 1"/>
        </material>
    </visual>
    <collision>
        <geometry>
            <box size="1 1 1"/>
        </geometry>
    </collision>
</link>

<link name="base"></link>

<link name="shoulder_yaw_link"/>

<link name="arm">
    <visual>
        <geometry>
            <box size="0.5 0.5 2"/>
        </geometry>
        <material name="green">
            <color rgba="0 1 0 1"/>
        </material>
    </visual>
    <collision>
        <geometry>
            <box size="0.5 0.5 2"/>
        </geometry>
    </collision>
    <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 0"/>
        <inertia
            ixx="0.1" ixy="0.0" ixz="0.0"
            iyy="0.1" iyz="0.0"
            izz="0.1"/>
    </inertial>
</link>

<link name="wrist">
    <visual>
        <geometry>
            <box size="0.75 0.5 0.5"/>
        </geometry>
        <material name="blue">
            <color rgba="0 0 1 1"/>
        </material>
    </visual>
    <collision>
        <geometry>
            <box size="0.75 0.5 0.5"/>
        </geometry>
    </collision>
    <inertial>
    <mass value="0.25"/>
    <origin xyz="0 0 0"/>
        <inertia
            ixx="0.1" ixy="0.0" ixz="0.0"
            iyy="0.1" iyz="0.0"
            izz="0.1"/>
    </inertial>
</link>


<joint name="base_to_chassis" type="fixed">
    <parent link="base"/>
    <child link="chassis"/>
    <origin xyz="1 0 0" rpy="0 0 0"/>
</joint>

<joint name="shoulder_yaw" type="revolute">
    <parent link="chassis"/>
    <child link="shoulder_yaw_link"/>
    <origin xyz="0 0 0.5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
</joint>

<joint name="arm_joint" type="revolute">
    <parent link="shoulder_yaw_link"/>
    <child link="arm"/>
    <origin xyz="0 0 1"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.435" upper="0.435" effort="10" velocity="1"/>
</joint>

<joint name="wrist_joint" type="revolute">
    <parent link="arm"/>
    <child link="wrist"/>
    <origin xyz="0.5 0 0.75"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
</joint>

</robot>